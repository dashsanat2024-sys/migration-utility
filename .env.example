# PostgreSQL (local Docker or Neon for production)
# Neon: use pooled connection string + sslmode=require
# Example: postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://migration:migration@localhost:5432/migration_utility

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO

# File landing zone for extract uploads
LANDING_ZONE_PATH=./data/landing

# Target adapter export path (file_export adapter)
EXPORT_PATH=./data/exports

# Kraken migration API (mock by default)
KRAKEN_MOCK_MODE=true
KRAKEN_API_URL=https://api.kraken.tech/migration/v1

# SAP IDoc integration (mock by default)
SAP_MOCK_MODE=true
SAP_API_URL=https://sap.example.local/idoc

# CORS (comma-separated origins for React dev + Docker UI)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost

# Runner / worker (Docker Compose)
RUNNER_MODE=api
ASYNC_RUNS_ENABLED=true
RUN_CHUNK_SIZE=500
WORKER_POLL_SECONDS=5

# Destination load batching (live Kraken / high-volume)
LOAD_BATCH_SIZE=200
LOAD_CONCURRENCY=4
LOAD_MAX_RPS=0
LOAD_RETRY_MAX=5
LOAD_RETRY_BASE_SECONDS=1.0

# ── AI-assisted layer (LangChain — suggests only, never writes to Kraken) ──
AI_ENABLED=true
AI_MOCK_MODE=false
AI_FORCE_HEURISTIC=false
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini
AI_MODEL=gpt-4o-mini
